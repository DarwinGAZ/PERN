generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  role      Role @default(USER)

  messages   Message[]
  services   Service[]
  proposals  Proposal[]
  reviewsGiven  Review[] @relation("ReviewAuthor")
  reviewsRecv   Review[] @relation("ReviewTarget")
}

enum Role {
  USER
  ADMIN
}

model Service {
  id          String   @id @default(uuid())
  title       String
  description String
  price       Float
  location    String
  status     ServiceStatus @default(OPEN)
  createdAt   DateTime @default(now())

  messages Message[]
  ownerId String
  owner   User @relation(fields: [ownerId], references: [id])

  proposals Proposal[]
}

enum ServiceStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
}

model Proposal {
  id        String   @id @default(uuid())
  message   String
  price     Float
  status    ProposalStatus @default(PENDING)
  createdAt DateTime @default(now())

  serviceId String
  service   Service @relation(fields: [serviceId], references: [id])

  applicantId String
  applicant   User @relation(fields: [applicantId], references: [id])
}

enum ProposalStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model Review {
  id        String   @id @default(uuid())
  rating    Int
  comment   String?
  createdAt DateTime @default(now())

  authorId String
  author   User @relation("ReviewAuthor", fields: [authorId], references: [id])

  targetId String
  target   User @relation("ReviewTarget", fields: [targetId], references: [id])
}

model Message {
  id        String   @id @default(uuid())
  content   String
  createdAt DateTime @default(now())

  senderId String
  sender   User   @relation(fields: [senderId], references: [id])

  serviceId String
  service   Service @relation(fields: [serviceId], references: [id])
}

