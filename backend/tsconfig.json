{
    "compilerOptions": {
        "rootDir": "./src",
        "outDir": "./dist",

        "module": "nodenext",
        "moduleResolution": "nodenext",
        "target": "esnext",

        "types": ["node"],

        "sourceMap": true,

        "strict": true,
        "isolatedModules": true,
        "noUncheckedIndexedAccess": true,
        "exactOptionalPropertyTypes": true,

        "skipLibCheck": true
    },
    "include": ["src"]
}
