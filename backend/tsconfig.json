{
    "compilerOptions": {
        "rootDir": ".",
        "outDir": "./dist",
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "target": "esnext",
        "types": ["node"],
        "sourceMap": true,
        "strict": true,
        "isolatedModules": true,
        "noUncheckedIndexedAccess": true,
        "exactOptionalPropertyTypes": false,
        "skipLibCheck": true
    },
    "include": ["src", "generated"]
}
